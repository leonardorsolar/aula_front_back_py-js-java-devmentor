# Normaliza line endings para LF no repositório
* text=auto

# Scripts shell sempre com LF
*.sh text eol=lf
mvnw text eol=lf

# Scripts Windows sempre com CRLF
*.cmd text eol=crlf
*.bat text eol=crlf

# Arquivos binários — sem conversão
*.jar binary
*.class binary
*.png binary
*.jpg binary
*.gif binary
*.ico binary
